rules_version = '2';
// Publicado via GitHub Actions
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isUserAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(['isAdmin'])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Professor: gerência (ver usuários, editar conteúdo) sem ser admin do sistema.
    // Substitui o antigo "admin comum" — só o super admin (email fixo) concede/remove
    // isAdmin/isProfessor/bloqueado (ver regra de update abaixo).
    function isProfessor() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(['isProfessor'])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isProfessor == true;
    }

    function canManage() {
      return isUserAdmin() || isProfessor();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'nome', 'avatar', 'email'])
        && data.id is string
        && data.nome is string && data.nome.size() > 0 && data.nome.size() <= 50
        && (!data.keys().hasAny(['turma']) || data.turma is string)
        && data.avatar is string && data.avatar.size() > 0 && data.avatar.size() <= 1048576
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && (!data.keys().hasAny(['criadoEm']) || data.criadoEm is string)
        && (!data.keys().hasAny(['isAdmin']) || data.isAdmin is bool)
        && (!data.keys().hasAny(['isProfessor']) || data.isProfessor is bool)
        && (!data.keys().hasAny(['isGuest']) || data.isGuest is bool)
        && (!data.keys().hasAny(['bloqueado']) || data.bloqueado is bool)
        && (!data.keys().hasAny(['telefone']) || (data.telefone is string && data.telefone.size() <= 20))
        && (!data.keys().hasAny(['whatsappOptIn']) || data.whatsappOptIn is bool)
        && (!data.keys().hasAny(['manualNotification']) || data.manualNotification is map)
        && (!data.keys().hasAny(['track']) || data.track in ['teen', 'youngAdult', 'adult'])
        && (!data.keys().hasAny(['locationId']) || (data.locationId is string && data.locationId.size() > 0 && data.locationId.size() <= 200))
        && (!data.keys().hasAny(['inviteCode']) || (data.inviteCode is string && data.inviteCode.size() <= 40));
    }

    // Uma vez definidos pelo próprio usuário no cadastro, track/locationId só
    // podem ser trocados por admin (ver bloco de update abaixo) — impede que o
    // usuário se mova de local/trilha sozinho depois de escolher.
    function ownerLocationTrackUnchanged() {
      return (!existing().keys().hasAny(['locationId']) || incoming().locationId == existing().locationId)
        && (!existing().keys().hasAny(['track']) || incoming().track == existing().track);
    }

    // Matrícula só por convite: o dono só grava um locationId novo se for
    // admin/professor (que fazem o setup e não precisam de código) OU se
    // apresentar um inviteCode ativo cujo local+trilha batem com o que está
    // gravando. Sem isto, dava pra entrar em qualquer local pelo console/API.
    function inviteCodeMatchesIncoming() {
      return incoming().keys().hasAny(['inviteCode'])
        && incoming().inviteCode is string
        && exists(/databases/$(database)/documents/inviteCodes/$(incoming().inviteCode))
        && get(/databases/$(database)/documents/inviteCodes/$(incoming().inviteCode)).data.active == true
        && get(/databases/$(database)/documents/inviteCodes/$(incoming().inviteCode)).data.locationId == incoming().locationId
        && get(/databases/$(database)/documents/inviteCodes/$(incoming().inviteCode)).data.track == incoming().track;
    }

    // true quando o dono está DEFININDO um locationId que ainda não existia
    function ownerSettingNewLocation() {
      return !existing().keys().hasAny(['locationId']) && incoming().keys().hasAny(['locationId']);
    }
    function ownerLocationAllowedOnUpdate() {
      return !ownerSettingNewLocation() || canManage() || inviteCodeMatchesIncoming();
    }
    function ownerLocationAllowedOnCreate() {
      return !incoming().keys().hasAny(['locationId']) || canManage() || inviteCodeMatchesIncoming();
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || canManage();

      allow create: if isOwner(userId)
        && incoming().id == userId
        && incoming().keys().hasOnly(['id', 'nome', 'turma', 'avatar', 'email', 'criadoEm', 'isAdmin', 'isProfessor', 'isGuest', 'bloqueado', 'telefone', 'whatsappOptIn', 'manualNotification', 'track', 'locationId', 'inviteCode'])
        && (!incoming().keys().hasAny(['isAdmin']) || incoming().email.lower() == 'robsonbraz67@gmail.com')
        && ownerLocationAllowedOnCreate()
        && isValidUser(incoming());

      allow update: if (isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'turma', 'avatar', 'isAdmin', 'criadoEm', 'telefone', 'whatsappOptIn', 'manualNotification', 'track', 'locationId', 'inviteCode'])
        && incoming().id == existing().id
        && incoming().email == existing().email
        && (!incoming().diff(existing()).affectedKeys().hasAny(['isAdmin']) || incoming().email.lower() == 'robsonbraz67@gmail.com')
        && ownerLocationTrackUnchanged()
        && ownerLocationAllowedOnUpdate()
        && isValidUser(incoming())) || (
        isUserAdmin()
        && incoming().diff(existing()).affectedKeys().hasAny(['isAdmin', 'isProfessor', 'isGuest', 'bloqueado', 'manualNotification', 'locationId', 'track'])
        && isValidUser(incoming()));

      allow delete: if isUserAdmin();
    }

    function isValidStudyLocation(data) {
      return data.keys().hasOnly(['name', 'createdBy', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 80
        && data.createdBy is string;
    }

    match /studyLocations/{locationId} {
      // Todo usuário autenticado precisa listar locais para escolher no cadastro
      allow get, list: if isAuthenticated();

      // Locais são dado administrativo: só admin/professor cadastra (evita que
      // aluno comum polua o dropdown de cadastro com locais lixo/spam). Aluno
      // sem local disponível pede ao professor/admin para cadastrar.
      allow create: if canManage()
        && isValidStudyLocation(incoming())
        && incoming().createdBy == request.auth.uid
        && incoming().createdAt == request.time;

      allow update: if isValidStudyLocation(incoming())
        && incoming().createdBy == existing().createdBy
        && incoming().createdAt == existing().createdAt
        && ((isAuthenticated() && existing().createdBy == request.auth.uid) || isUserAdmin());

      allow delete: if isUserAdmin();
    }

    function isValidTeacherAssignment(data) {
      return data.keys().hasOnly(['locationId', 'assignedBy', 'assignedAt'])
        && data.locationId is string && data.locationId.size() > 0
        && data.assignedBy is string
        && data.assignedAt == request.time;
    }

    // Doc id == uid do professor. Só admin define/altera; o próprio professor
    // (e o admin) podem ler para saber a que local está vinculado.
    match /teacherAssignments/{teacherId} {
      allow get: if isOwner(teacherId) || isUserAdmin();
      allow list: if isUserAdmin();
      allow create, update: if isUserAdmin()
        && isValidTeacherAssignment(incoming())
        && incoming().assignedBy == request.auth.uid; // audit trail não forjável
      allow delete: if isUserAdmin();
    }

    function isValidInviteCode(data) {
      return data.keys().hasOnly(['code', 'locationId', 'track', 'active', 'createdBy', 'createdAt'])
        && data.code is string && data.code.size() >= 4 && data.code.size() <= 40
        && data.locationId is string && data.locationId.size() > 0 && data.locationId.size() <= 200
        && data.track in ['teen', 'youngAdult', 'adult']
        && data.active is bool
        && data.createdBy is string;
    }

    // Local ao qual o professor autenticado está atribuído (teacherAssignments/{uid}).
    // Usada só depois de checar exists(), para não estourar em quem não é professor.
    function myTeacherLocation() {
      return get(/databases/$(database)/documents/teacherAssignments/$(request.auth.uid)).data.locationId;
    }

    // Professor só pode emitir convite para o local exatamente atribuído a ele.
    // É a trava central da Etapa 3: sem isto, dava pra emitir código de qualquer
    // local via console/API mesmo com a UI restringindo.
    function professorCanIssueFor(locationId) {
      return isProfessor()
        && exists(/databases/$(database)/documents/teacherAssignments/$(request.auth.uid))
        && myTeacherLocation() == locationId;
    }

    match /inviteCodes/{codeId} {
      // Resgate: precisa saber o código exato (== doc id). list só p/ quem gerencia,
      // pra ninguém enumerar todos os códigos do sistema.
      allow get: if isAuthenticated();
      allow list: if canManage();

      // Admin cria para qualquer local+trilha; professor só para o local atribuído.
      allow create: if isValidInviteCode(incoming())
        && codeId == incoming().code
        && incoming().createdBy == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().active == true
        && (isUserAdmin() || professorCanIssueFor(incoming().locationId));

      // Revogar/reativar: admin qualquer um, professor só os que ele criou.
      // Só o campo 'active' pode mudar — local/trilha/código são imutáveis.
      allow update: if isValidInviteCode(incoming())
        && incoming().code == existing().code
        && incoming().locationId == existing().locationId
        && incoming().track == existing().track
        && incoming().createdBy == existing().createdBy
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['active'])
        && (isUserAdmin() || (isProfessor() && existing().createdBy == request.auth.uid));

      allow delete: if isUserAdmin() || (isProfessor() && existing().createdBy == request.auth.uid);
    }

    // ===== Estudo em Dupla (Etapa 4) =====
    // Local+trilha do usuário autenticado batem com os passados? (escopo social)
    function myLocationTrackMatches(loc, trk) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.locationId == loc
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.track == trk;
    }

    function isValidPairInvite(data) {
      return data.keys().hasOnly(['createdBy', 'createdByName', 'createdByAvatar', 'locationId', 'track', 'type', 'status', 'createdAt', 'expiresAt'])
        && data.createdBy is string
        && data.createdByName is string && data.createdByName.size() <= 50
        && data.createdByAvatar is string && data.createdByAvatar.size() <= 1048576
        && data.locationId is string && data.locationId.size() > 0
        && data.track in ['teen', 'youngAdult', 'adult']
        && data.type in ['family', 'couple', 'friend']
        && data.status in ['pending', 'accepted', 'expired']
        && data.expiresAt is timestamp;
    }

    match /pairInvites/{inviteId} {
      // Resgate por link: precisa saber o inviteId (doc id). list só dos próprios.
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && resource.data.createdBy == request.auth.uid;

      // Só convida para o próprio local+trilha (validado no servidor).
      allow create: if isAuthenticated()
        && incoming().createdBy == request.auth.uid
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && isValidPairInvite(incoming())
        && myLocationTrackMatches(incoming().locationId, incoming().track);

      allow update: if isAuthenticated() && (
          // criador cancela o convite
          (existing().createdBy == request.auth.uid
           && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
           && incoming().status == 'expired')
          ||
          // quem aceita marca como aceito: precisa ser de outro usuário, ainda
          // válido, e do mesmo local+trilha
          (existing().status == 'pending'
           && existing().createdBy != request.auth.uid
           && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
           && incoming().status == 'accepted'
           && existing().expiresAt > request.time
           && myLocationTrackMatches(existing().locationId, existing().track))
        );

      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    function isValidPair(data) {
      return data.keys().hasOnly(['inviteId', 'members', 'userA', 'userB', 'userAName', 'userAAvatar', 'userBName', 'userBAvatar', 'locationId', 'track', 'type', 'active', 'createdAt', 'sharesA', 'sharesB'])
        && data.members is list && data.members.size() == 2
        && data.userA is string && data.userB is string
        && data.members[0] == data.userA && data.members[1] == data.userB
        && data.userA != data.userB
        && data.locationId is string && data.track in ['teen', 'youngAdult', 'adult']
        && data.type in ['family', 'couple', 'friend']
        && data.active is bool
        && data.sharesA is map && data.sharesB is map;
    }

    match /pairs/{pairId} {
      // Só os dois membros leem a dupla (e seu conteúdo compartilhado).
      allow get, list: if isAuthenticated() && request.auth.uid in resource.data.members;

      // Quem aceita (userB) cria o doc; pairId == inviteId garante uso único
      // (segunda tentativa colide com doc existente). Valida o convite e o
      // próprio local+trilha do aceitante.
      allow create: if isAuthenticated()
        && pairId == incoming().inviteId
        && incoming().userB == request.auth.uid
        && incoming().active == true
        && incoming().sharesA.size() == 0
        && incoming().sharesB.size() == 0
        && isValidPair(incoming())
        && exists(/databases/$(database)/documents/pairInvites/$(pairId))
        && get(/databases/$(database)/documents/pairInvites/$(pairId)).data.status == 'pending'
        && get(/databases/$(database)/documents/pairInvites/$(pairId)).data.createdBy == incoming().userA
        && get(/databases/$(database)/documents/pairInvites/$(pairId)).data.locationId == incoming().locationId
        && get(/databases/$(database)/documents/pairInvites/$(pairId)).data.track == incoming().track
        && get(/databases/$(database)/documents/pairInvites/$(pairId)).data.expiresAt > request.time
        && myLocationTrackMatches(incoming().locationId, incoming().track);

      // Desfazer a dupla (active=false) ou cada membro editar só o SEU campo de
      // compartilhamento (sharesA para userA, sharesB para userB) — ninguém
      // altera o compartilhamento do outro.
      allow update: if isAuthenticated() && (request.auth.uid in existing().members) && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['active']) && incoming().active == false)
          ||
          (request.auth.uid == existing().userA && incoming().diff(existing()).affectedKeys().hasOnly(['sharesA']))
          ||
          (request.auth.uid == existing().userB && incoming().diff(existing()).affectedKeys().hasOnly(['sharesB']))
        );

      allow delete: if isUserAdmin();
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['userId', 'week', 'xp', 'streak', 'nome', 'avatar'])
        && data.userId is string
        && data.week is string && data.week.size() > 0 && data.week.size() <= 20
        && (!data.keys().hasAny(['trimestre']) || data.trimestre is string)
        && data.xp is number
        && data.streak is number
        && data.nome is string
        && data.avatar is string
        && (!data.keys().hasAny(['done']) || data.done is list)
        && (!data.keys().hasAny(['history']) || data.history is map)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt == request.time)
        && (!data.keys().hasAny(['isAdmin']) || data.isAdmin is bool)
        && (!data.keys().hasAny(['isGuest']) || data.isGuest is bool)
        && (!data.keys().hasAny(['isProfessor']) || data.isProfessor is bool);
    }

    match /progress/{progressId} {
      // Anyone authenticated can read for ranking
      allow get, list: if isAuthenticated();

      allow create: if isAuthenticated()
        && progressId == incoming().userId + '_' + incoming().week
        && isOwner(incoming().userId)
        && incoming().keys().hasOnly(['userId', 'week', 'trimestre', 'xp', 'streak', 'done', 'history', 'nome', 'avatar', 'isAdmin', 'isGuest', 'isProfessor', 'updatedAt'])
        && isValidProgress(incoming())
        && exists(/databases/$(database)/documents/users/$(incoming().userId));

      allow update: if isAuthenticated()
        && isOwner(existing().userId)
        && incoming().userId == existing().userId
        && incoming().week == existing().week
        && incoming().diff(existing()).affectedKeys().hasOnly(['trimestre', 'xp', 'streak', 'done', 'history', 'nome', 'avatar', 'isAdmin', 'isGuest', 'isProfessor', 'updatedAt'])
        && isValidProgress(incoming());

      allow delete: if false;
    }

    function isValidOverride(data) {
      return (!data.keys().hasAny(['titulo']) || data.titulo is string)
        && (!data.keys().hasAny(['conteudo']) || data.conteudo is string)
        && (!data.keys().hasAny(['versiculoChave']) || (data.versiculoChave is map && data.versiculoChave.keys().hasAll(['texto','referencia'])))
        && (!data.keys().hasAny(['perguntas']) || data.perguntas is list)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt == request.time);
    }

    match /conteudoOverrides/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update: if canManage() && isValidOverride(incoming());
      allow delete: if isUserAdmin();
    }
  }
}
