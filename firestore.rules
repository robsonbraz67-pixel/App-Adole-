rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'nome', 'avatar', 'email'])
        && data.id is string
        && data.nome is string && data.nome.size() > 0 && data.nome.size() <= 50
        && data.turma is string && data.turma.size() <= 50
        && data.avatar is string && data.avatar.size() > 0 && data.avatar.size() <= 10
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && (!data.keys().hasAny(['criadoEm']) || data.criadoEm is string);
    }

    match /users/{userId} {
      // Users can only read their own data, ranking only needs progress
      // But maybe we allow reading all users for showing profile details if needed?
      // Since email is here, we should isolate it or restrict read to owner.
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId)
        && incoming().id == userId
        && incoming().keys().hasOnly(['id', 'nome', 'turma', 'avatar', 'email', 'criadoEm'])
        && isValidUser(incoming());
        
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'turma', 'avatar'])
        && incoming().id == existing().id
        && incoming().email == existing().email
        && isValidUser(incoming());
        
      allow delete: if false;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['userId', 'week', 'xp', 'streak', 'nome', 'avatar'])
        && data.userId is string
        && data.week is string && data.week.size() > 0 && data.week.size() <= 20
        && data.xp is number
        && data.streak is number
        && data.nome is string && data.nome.size() <= 50
        && data.avatar is string && data.avatar.size() <= 10
        && (!data.keys().hasAny(['done']) || data.done is list && data.done.size() <= 7)
        && (!data.keys().hasAny(['history']) || data.history is map)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt == request.time);
    }

    match /progress/{progressId} {
      // Anyone authenticated can read for ranking
      allow get, list: if isAuthenticated();

      allow create: if isAuthenticated()
        && progressId == incoming().userId + '_' + incoming().week
        && isOwner(incoming().userId)
        && incoming().keys().hasOnly(['userId', 'week', 'xp', 'streak', 'done', 'history', 'nome', 'avatar', 'updatedAt'])
        && isValidProgress(incoming())
        && exists(/databases/$(database)/documents/users/$(incoming().userId));
        
      allow update: if isAuthenticated()
        && isOwner(existing().userId)
        && incoming().userId == existing().userId
        && incoming().week == existing().week
        && incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'streak', 'done', 'history', 'nome', 'avatar', 'updatedAt'])
        && isValidProgress(incoming());

      allow delete: if false;
    }
  }
}
